# =========================================================
# OLLAMA LLM CONFIGURATION
# =========================================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=4096

# =========================================================
# EMBEDDINGS
# =========================================================
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large

# =========================================================
# TEXT SPLITTING
# =========================================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# =========================================================
# APP METADATA
# =========================================================
APP_TITLE=Autonomous Business OS Demo
APP_DESCRIPTION=AI-Powered Business Management with RAG
APP_THEME=soft
